generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
  TRIALING
  EXPIRED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  READY
  FAILED
  CANCELED
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ProviderType {
  ANTHROPIC
  OPENAI
  DEEPSEEK
  GOOGLE
  GROQ
  XIAOMI
  OPENROUTER
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  emailVerified DateTime?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  accounts       Account[]
  subscriptions  Subscription[]
  projects       Project[]
  conversations  Conversation[]
  messages       Message[]
  usageRecords   UsageRecord[]
  auditEvents    AuditEvent[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id              String  @id @default(cuid())
  userId          String
  type            String
  provider        String
  providerAccountId String
  refreshToken    String? @map("refresh_token")
  accessToken     String? @map("access_token")
  expiresAt       Int?    @map("expires_at")
  tokenType       String? @map("token_type")
  scope           String?
  idToken         String? @map("id_token")
  sessionState    String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  stripeCustomerId String?            @map("stripe_customer_id")
  stripeSubscriptionId String?        @map("stripe_subscription_id")
  status           SubscriptionStatus @default(TRIALING)
  tier             String             @default("FREE")
  currentPeriodEnd DateTime?          @map("current_period_end")
  cancelAtPeriodEnd Boolean           @default(false) @map("cancel_at_period_end")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Project {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  vfsSnapshot Json?    @map("vfs_snapshot")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  versions  ProjectVersion[]
  deployments Deployment[]
  generations  Generation[]
  conversations Conversation[]

  @@map("projects")
}

model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  snapshot  Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_versions")
}

model Deployment {
  id        String           @id @default(cuid())
  projectId String
  provider  String           @default("vercel")
  url       String?
  status    DeploymentStatus @default(PENDING)
  logs      Json?
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events    DeploymentEvent[]

  @@map("deployments")
}

model Generation {
  id         String           @id @default(cuid())
  projectId  String
  prompt     String
  result     Json?
  tokensUsed Int?             @map("tokens_used")
  provider   ProviderType?
  model      String?
  status     GenerationStatus @default(QUEUED)
  error      String?
  duration   Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  GenerationEvent[]

  @@map("generations")
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  action    String
  count     Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action])
  @@index([userId, createdAt])
  @@map("usage_records")
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String
  content        String
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("audit_events")
}

model GenerationEvent {
  id           String   @id @default(cuid())
  generationId String
  type         String
  data         Json?
  createdAt    DateTime @default(now())

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("generation_events")
}

model DeploymentEvent {
  id           String   @id @default(cuid())
  deploymentId String
  type         String
  data         Json?
  createdAt    DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@map("deployment_events")
}
